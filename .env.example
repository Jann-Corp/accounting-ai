# Database
DB_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:postgres@db:5432/accounting

# JWT Token
SECRET_KEY=change-me-in-production

# Qwen API (AI receipt recognition)
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-vl-plus
AI_RECOGNITION_PROMPT=你是一个专业的票据识别助手。请从图片中提取所有消费记录，包括金额、商户名称、日期和分类。

# File Upload
UPLOAD_DIR=/tmp/accounting-uploads
MAX_UPLOAD_SIZE=10485760

# AI Confidence Threshold (0.0-1.0)
AI_CONFIDENCE_THRESHOLD=0.85

# Ports (optional, defaults shown)
# BACKEND_PORT=8000
# FRONTEND_PORT=3000
